# Required if using a real LLM provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: OpenAI-compatible URL for local inference (Ollama: http://localhost:11434/v1)
OPENAI_BASE_URL=

# Optional: LangSmith (when LANGSMITH_API_KEY is set, LLM calls are traced via wrap_openai)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=multi-agent-research-lab
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional search provider
TAVILY_API_KEY=

# Runtime config
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=6
TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
MIN_FINAL_ANSWER_CHARS=80

# Optional: cost estimation for benchmark (set if you want USD estimates)
# Example: 0.00015 means $0.00015 per 1K tokens
BENCHMARK_USD_PER_1K_INPUT_TOKENS=
BENCHMARK_USD_PER_1K_OUTPUT_TOKENS=
